# === Домены (DNS A-запись должна указывать на IP сервера) ===
DOMAIN=elektromontazh.ru
ADMIN_DOMAIN=admin.elektromontazh.ru
ACME_EMAIL=info@elektromontazh.ru

# === PostgreSQL ===
POSTGRES_PASSWORD=generate_a_long_random_password_here

# === RabbitMQ ===
RABBITMQ_USER=elektrika
RABBITMQ_PASSWORD=generate_a_long_random_password_here

# === JWT (минимум 32 символа) ===
JWT_SECRET=generate_a_long_random_secret_at_least_32_characters

# === Admin (создаётся при первом запуске, если пользователя ещё нет) ===
ADMIN_INITIAL_PASSWORD=generate_a_strong_admin_password

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Comma-separated Telegram user IDs (each person must /start the bot first)
TELEGRAM_CHAT_IDS=5143241640,123456789,987654321
